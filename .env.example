# Salin fail ini kepada .env dan isi nilai sebenar. JANGAN commit .env ke git.

PORT=5001

# Pangkalan data MySQL
DB_HOST=localhost
DB_USER=root
DB_PASS=                      # WAJIB tetapkan kata laluan DB (jangan kosong di production)
DB_NAME=kelab_perhilitan

# Rahsia JWT — jana yang panjang & rawak:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti_dengan_rahsia_rawak_panjang

# Konfigurasi E-mel (Gmail App Password)
EMAIL_USER=contoh@gmail.com
EMAIL_PASS=                   # Gmail App Password (16 aksara)

# URL frontend & backend
FRONTEND_URL=https://kelabperhilitan.my
BACKEND_URL=https://api.kelabperhilitan.my

# ToyyibPay
TOYYIBPAY_URL=https://dev.toyyibpay.com/index.php/api/createBill
SECRET_KEY=                   # userSecretKey dari ToyyibPay
CATEGORY_CODE=                # categoryCode dari ToyyibPay

# Kata laluan akses Dashboard AIGEO
AIGEO_PASS=
